# =============================================================================
# .env.example — Variables del compose unificado de OpenCapacity
#
# Copiar a .env y ajustar antes de levantar el stack en produccion:
#   cp .env.example .env
#
# NOTA: para desarrollo (docker compose up) los defaults del compose alcanzan;
# este archivo solo es necesario al usar docker-compose.prod.yml.
# NUNCA commitear el archivo .env al repositorio.
# =============================================================================

# --- Frontend ----------------------------------------------------------------
# URL publica que usa el browser para hablar con la API
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# --- API ---------------------------------------------------------------------
# Generar con: openssl rand -hex 32
SECRET_KEY=cambiar_en_produccion_generado_con_openssl_rand_hex_32

# Origenes permitidos en CORS (lista separada por comas)
ALLOWED_ORIGINS=http://localhost:3000

# Prefijo de la API (sincronizar con el frontend si se cambia)
API_V1_PREFIX=/api/v1

# Modo debug (NUNCA true en produccion)
DEBUG=false

# --- PostgreSQL --------------------------------------------------------------
POSTGRES_DB=hosting_capacity
POSTGRES_USER=hosting_user
POSTGRES_PASSWORD=cambiar_password_seguro

DATABASE_URL=postgresql://hosting_user:cambiar_password_seguro@postgres:5432/hosting_capacity

# --- Redis -------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# --- Celery ------------------------------------------------------------------
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_TASK_TIMEOUT_SECONDS=3600

# NUNCA cambiar a mas de 1. OpenDSS no es thread-safe.
CELERY_WORKER_CONCURRENCY=1
