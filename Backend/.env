# =============================================================================
# .env.example — Variables de entorno del backend
#
# Copiar a .env y ajustar los valores antes de levantar los servicios:
#   cp .env.example .env
#
# NUNCA commitear el archivo .env al repositorio.
# =============================================================================

# --- API ---------------------------------------------------------------------
# Clave secreta para firmar tokens JWT (cambiar en produccion)
SECRET_KEY=cambiar_en_produccion_generado_con_openssl_rand_hex_32

# Origenes permitidos en CORS (lista separada por comas)
ALLOWED_ORIGINS='["http://localhost:3000","http://localhost:5173"]'

# Prefijo de la API (no cambiar si no se actualiza nginx.conf)
API_V1_PREFIX=/api/v1

# Modo debug (nunca true en produccion)
DEBUG=true

# --- Base de datos (PostgreSQL) ----------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/hosting_capacity

# Para produccion con usuario dedicado:
# DATABASE_URL=postgresql://hosting_user:password_seguro@db_host:5432/hosting_capacity

# --- Redis -------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# --- Celery ------------------------------------------------------------------
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Timeout de 1 hora para la busqueda binaria en circuitos grandes
CELERY_TASK_TIMEOUT_SECONDS=3600

# NUNCA cambiar a mas de 1. OpenDSS no es thread-safe.
CELERY_WORKER_CONCURRENCY=1

# --- OpenDSS / Circuito ------------------------------------------------------
# Tiempo de vida del circuito compilado en Redis (2 horas = 7200 segundos)
CIRCUIT_TTL_SECONDS=7200

# Limite absoluto de potencia GD aceptado por la API (10 GW)
MAX_POWER_KW_LIMIT=10000000

# Potencia maxima default para la busqueda binaria
DEFAULT_MAX_POWER_KW=1500000

# --- PostgreSQL (solo para docker-compose.prod.yml) --------------------------
POSTGRES_DB=hosting_capacity
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
